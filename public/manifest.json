{
  "manifest_version": 3,
  "name": "SIDEFMT",
  "version": "1.0.0",
  "description": "Side panel: JSON, Prettier code format, Markdown, diff. Runs locally.",
  "minimum_chrome_version": "114",
  "permissions": ["clipboardWrite", "storage", "sidePanel", "windows"],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "action": {
    "default_title": "SIDEFMT",
    "default_icon": {
      "16": "icons/icon16.png",
      "24": "icons/icon24.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "96": "icons/icon96.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "24": "icons/icon24.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png"
  }
}
