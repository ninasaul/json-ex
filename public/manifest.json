{
  "manifest_version": 3,
  "name": "JsonEx - JSON Formatter",
  "version": "1.0.0",
  "description": "Format, validate, and beautify JSON with syntax highlighting",
  "minimum_chrome_version": "114",
  "permissions": ["clipboardWrite", "storage", "sidePanel", "windows"],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "action": {
    "default_title": "JsonEx",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
